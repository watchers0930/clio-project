# =============================================================================
# CLIO Platform - 환경변수 템플릿
# 이 파일을 .env.local 로 복사한 뒤 실제 값을 입력하세요
# =============================================================================

# Supabase 프로젝트 URL (대시보드 > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=your-project-url

# Supabase 익명 키 (클라이언트 측 접근용)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase 서비스 롤 키 (서버 측 관리자 접근용, 절대 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI API 키 (문서 생성, 임베딩, STT 기능에 필수)
OPENAI_API_KEY=sk-proj-your-openai-key

# 내부 API 인증 시크릿 (파일 처리 백그라운드 API 보호용)
INTERNAL_API_SECRET=your-internal-secret

# 업로드 후 만료일 자동 추출 활성화 여부 (비용성 GPT 호출, 기본 비활성화 권장)
ENABLE_AUTO_EXPIRY_EXTRACTION=false

# 검색 결과별 AI 요약 활성화 여부 (결과 수만큼 OpenAI 호출 발생, 기본 비활성화 권장)
ENABLE_SEARCH_AI_SUMMARY=false
